#!/bin/bash
#PBS -q a64fx
#PBS -l select=1:ncpus=48
#PBS -l walltime=01:00:00
#PBS -joe

cd "$RUN_DIR" || exit 2

export OMP_NUM_THREADS=48 OMP_PLACES=cores OMP_PROC_BIND=spread
date

case "$MODEL" in
    omp)
        "./$BENCHMARK_EXE"
        ;;
    *)
        echo "Unknown run configuration for model '$MODEL'"
        exit 1
        ;;
esac

